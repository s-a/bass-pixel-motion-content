{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bass-pixel-motion.local/schema/feature-params.schema.v1.json",
  "title": "Feature Params Registry",
  "type": "object",
  "required": [
    "kind",
    "version",
    "name",
    "description",
    "provenance",
    "value_types",
    "audio",
    "manifest_publications"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "feature-params-registry"
    },
    "version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "required": [
        "scene_shader_manifest_schema",
        "scene_shader_document_types",
        "audio_source_validation",
        "audio_source_metadata",
        "audio_drive_metadata",
        "audio_drive_rules",
        "audio_resolution_rules",
        "scene_formula"
      ],
      "properties": {
        "scene_shader_manifest_schema": {
          "type": "string",
          "minLength": 1
        },
        "scene_shader_document_types": {
          "type": "string",
          "minLength": 1
        },
        "audio_source_validation": {
          "type": "string",
          "minLength": 1
        },
        "audio_source_metadata": {
          "type": "string",
          "minLength": 1
        },
        "audio_drive_metadata": {
          "type": "string",
          "minLength": 1
        },
        "audio_drive_rules": {
          "type": "string",
          "minLength": 1
        },
        "audio_resolution_rules": {
          "type": "string",
          "minLength": 1
        },
        "scene_formula": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "value_types": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/valueType"
      },
      "minItems": 1
    },
    "audio": {
      "type": "object",
      "required": [
        "notes",
        "value_domains",
        "response_curves",
        "analysis_modules",
        "exact_sources",
        "source_families",
        "derived_families"
      ],
      "properties": {
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "value_domains": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/valueDomain"
          }
        },
        "response_curves": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/responseCurve"
          }
        },
        "analysis_modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/analysisModule"
          }
        },
        "exact_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/audioSource"
          }
        },
        "source_families": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/audioSourceFamily"
          }
        },
        "derived_families": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/derivedVariantFamily"
          }
        }
      },
      "additionalProperties": false
    },
    "manifest_publications": {
      "type": "object",
      "required": [
        "notes",
        "allowed_shader_value_types",
        "manifest_fields",
        "text_fields",
        "collection_contracts"
      ],
      "properties": {
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_shader_value_types": {
          "type": "array",
          "items": {
            "enum": ["float", "int", "bool", "vec2", "vec3", "vec4", "color"]
          },
          "uniqueItems": true
        },
        "manifest_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicationField"
          }
        },
        "text_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicationField"
          }
        },
        "collection_contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/collectionContract"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "namedRecord": {
      "type": "object",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "valueType": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object"
        }
      ]
    },
    "valueDomain": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "properties": {
            "default_min": {
              "type": "string",
              "minLength": 1
            },
            "default_max": {
              "type": ["string", "null"]
            }
          }
        }
      ]
    },
    "responseCurve": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object"
        }
      ]
    },
    "analysisModule": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": ["dependencies"],
          "properties": {
            "dependencies": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "audioSource": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": [
            "value_domain",
            "response_curve",
            "analysis_modules",
            "supports_drive_variant",
            "maturity"
          ],
          "properties": {
            "category": {
              "type": "string",
              "minLength": 1
            },
            "spectrum_range_hz": {
              "$ref": "#/$defs/hertzRange"
            },
            "drive_value_domain": {
              "type": "string",
              "minLength": 1
            },
            "value_domain": {
              "type": "string",
              "minLength": 1
            },
            "response_curve": {
              "type": "string",
              "minLength": 1
            },
            "analysis_modules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "min_value": {
              "type": ["string", "null"]
            },
            "max_value": {
              "type": ["string", "null"]
            },
            "supports_drive_variant": {
              "type": "boolean"
            },
            "note": {
              "type": "string"
            },
            "maturity": {
              "enum": ["production", "in-development", "research", "deprecated"]
            },
            "noise_floor_db": {
              "type": "number",
              "default": -60.0
            }
          }
        }
      ]
    },
    "hertzRange": {
      "type": "object",
      "required": ["min_hz"],
      "properties": {
        "min_hz": {
          "type": "number",
          "minimum": 0.0
        },
        "max_hz": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "familyIndexRange": {
      "type": "object",
      "required": ["min", "max", "width"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "familyMemberLabel": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": ["index"],
          "properties": {
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "audioSourceFamily": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": [
            "pattern",
            "index_range",
            "value_domain",
            "response_curve",
            "analysis_modules",
            "supports_drive_variant",
            "maturity"
          ],
          "properties": {
            "pattern": {
              "type": "string",
              "minLength": 1
            },
            "index_range": {
              "$ref": "#/$defs/familyIndexRange"
            },
            "group_note": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "minLength": 1
            },
            "label_strategy": {
              "type": "string"
            },
            "description_strategy": {
              "type": "string"
            },
            "sample_rate_dependent": {
              "type": "boolean"
            },
            "band_width_formula_hz": {
              "type": "string"
            },
            "drive_value_domain": {
              "type": "string",
              "minLength": 1
            },
            "value_domain": {
              "type": "string",
              "minLength": 1
            },
            "response_curve": {
              "type": "string",
              "minLength": 1
            },
            "analysis_modules": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "min_value": {
              "type": ["string", "null"]
            },
            "max_value": {
              "type": ["string", "null"]
            },
            "supports_drive_variant": {
              "type": "boolean"
            },
            "member_labels": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/familyMemberLabel"
              }
            },
            "maturity": {
              "enum": ["production", "in-development", "research", "deprecated"]
            }
          }
        }
      ]
    },
    "derivedVariantRule": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": ["when", "value_domain", "description_template"],
          "properties": {
            "when": {
              "type": "string",
              "minLength": 1
            },
            "value_domain": {
              "type": "string",
              "minLength": 1
            },
            "description_template": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "derivedVariantFamily": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": [
            "derived_prefix",
            "source_selector",
            "label_template",
            "rules"
          ],
          "properties": {
            "derived_prefix": {
              "type": "string",
              "minLength": 1
            },
            "source_selector": {
              "type": "string",
              "minLength": 1
            },
            "label_template": {
              "type": "string",
              "minLength": 1
            },
            "rules": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/derivedVariantRule"
              },
              "minItems": 1
            }
          }
        }
      ]
    },
    "publicationField": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": ["value_type", "required"],
          "properties": {
            "value_type": {
              "type": "string",
              "minLength": 1
            },
            "required": {
              "type": "boolean"
            },
            "pattern": {
              "type": "string"
            },
            "default": {},
            "exclusive_minimum": {
              "type": "number"
            },
            "minimum": {
              "type": "number"
            },
            "maximum": {
              "type": "number"
            },
            "enum_values": {
              "type": "array",
              "items": {}
            },
            "note": {
              "type": "string"
            }
          }
        }
      ]
    },
    "collectionContract": {
      "allOf": [
        {
          "$ref": "#/$defs/namedRecord"
        },
        {
          "type": "object",
          "required": ["container_type", "entry_kind"],
          "properties": {
            "container_type": {
              "enum": ["object", "array"]
            },
            "entry_kind": {
              "type": "string",
              "minLength": 1
            },
            "item_id_field": {
              "type": "string"
            },
            "item_id_pattern": {
              "type": "string"
            },
            "source_registry": {
              "type": "string"
            },
            "max_items": {
              "type": "integer",
              "minimum": 0
            },
            "fallback_to": {
              "type": "string"
            },
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/publicationField"
              }
            },
            "allowed_value_types": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "allowed_scopes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
